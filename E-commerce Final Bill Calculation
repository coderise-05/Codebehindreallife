<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Amazon Style Bill Calculator</title>

    <style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, sans-serif;
    }

    body{
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;

        background:linear-gradient(
            135deg,
            #667eea,
            #764ba2,
            #ff6b6b
        );
    }

    .card{

        width:380px;
        background:white;
        padding:25px;
        border-radius:20px;

        box-shadow:
        0px 10px 30px rgba(0,0,0,0.3);

        text-align:center;
    }

    .product{
        font-size:28px;
        font-weight:bold;
        color:#333;
    }

    .price{
        margin-top:10px;
        font-size:22px;
        color:#ff6600;
    }

    .qty-box{
        margin-top:25px;
    }

    button{

        border:none;
        cursor:pointer;
        transition:0.3s;
    }

    .qty-btn{

        width:45px;
        height:45px;
        border-radius:50%;
        font-size:22px;
        color:white;
    }

    .minus{
        background:#ff4d4d;
    }

    .plus{
        background:#00c853;
    }

    .qty-btn:hover{
        transform:scale(1.15);
    }

    #qty{
        font-size:25px;
        margin:0 20px;
        font-weight:bold;
    }

    .order-btn{

        margin-top:25px;
        padding:12px 25px;

        background:#ff9800;
        color:white;

        border-radius:10px;
        font-size:18px;
    }

    .order-btn:hover{

        background:#e68900;
        transform:scale(1.05);
    }

    #success{

        margin-top:15px;
        color:green;
        font-weight:bold;
        font-size:18px;
    }

    #bill{

        margin-top:20px;
        text-align:left;
        line-height:1.8;
    }

    </style>
</head>

<body>

<div class="card">

    <div class="product">
        Laptop Stand
    </div>

    <div class="price">
        ₹999
    </div>

    <div class="qty-box">

        <button
        class="qty-btn minus"
        onclick="decreaseQty()">
        -
        </button>

        <span id="qty">1</span>

        <button
        class="qty-btn plus"
        onclick="increaseQty()">
        +
        </button>

    </div> <br>

    <h2>Total ₹<span id="price">999</span></h2>
    
    <button
    class="order-btn"
    onclick="placeOrder()">

    Place Order

    </button>

    <div id="success"></div>

    <div id="bill"></div>

</div>

<script>

let price = 999;
let quantity = 1;

function updateprice(){
    document.getElementById("qty").innerText = quantity;
    document.getElementById("price").innerText = quantity * price;
}

function increaseQty(){

    quantity++;

    document.getElementById("qty").innerText =
    quantity;

    updateprice();
}

function decreaseQty(){

    if(quantity > 1){
        quantity--;
    }

    document.getElementById("qty").innerText =
    quantity;

    updateprice();
}

function placeOrder(){

    let subtotal =
    price * quantity;

    let gst =
    subtotal * 18 / 100;

    let shipping = 40;

    let handling = 10;

    let finalBill =
    subtotal +
    gst +
    shipping +
    handling;

    document.getElementById("success").innerHTML =
    "Order Placed Successfully!";

    document.getElementById("bill").innerHTML =

    `
    <hr><br>

    Quantity : ${quantity}<br>

    Product Total : ₹${subtotal}<br>

    GST (18%) : ₹${gst.toFixed(2)}<br>

    Shipping : ₹${shipping}<br>

    Handling Fee : ₹${handling}<br><br>

    <hr>

    <h3>
    Final Bill :
    ₹${finalBill.toFixed(2)}
    </h3>
    `;
}
</script>

</body>
</html>
